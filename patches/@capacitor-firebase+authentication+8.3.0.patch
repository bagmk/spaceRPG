@@ -0,0 +1,127 @@
+// CapacitorShim.swift
+// Provides missing CAPPluginCall/JSTypes APIs that the capacitor-swift-pm
+// xcframework conditionally hides behind $NonescapableTypes.
+
+import Foundation
+import WebKit
+import Capacitor
+
+// MARK: - CAPPluginCall shim
+
+extension CAPPluginCall {
+    @objc public func getString(_ key: String) -> String? {
+        return options?[key] as? String
+    }
+
+    public func getArray(_ key: String) -> JSArray? {
+        return options?[key] as? JSArray
+    }
+
+    public func getArray<T>(_ key: String, _ ofType: T.Type) -> [T]? {
+        return options?[key] as? [T]
+    }
+
+    public func getBool(_ key: String) -> Bool? {
+        return options?[key] as? Bool
+    }
+
+    public func getInt(_ key: String) -> Int? {
+        return options?[key] as? Int
+    }
+
+    public func getObject(_ key: String) -> JSObject? {
+        return options?[key] as? JSObject
+    }
+
+    @objc public func reject(_ message: String, _ code: String? = nil, _ error: Error? = nil, _ data: PluginCallResultData? = nil) {
+        // Use Obj-C runtime to construct CAPPluginCallError since its Swift
+        // init is gated behind $NonescapableTypes experimental feature.
+        let errorClass: AnyClass? = NSClassFromString("CAPPluginCallError")
+        if let errorClass = errorClass as? NSObject.Type {
+            let errorObj = errorClass.perform(
+                Selector(("initWithMessage:code:error:data:")),
+                with: message,
+                with: code
+            )?.takeUnretainedValue()
+            if let callError = errorObj as? CAPPluginCallError {
+                errorHandler?(callError)
+                return
+            }
+        }
+        // Fallback: just call the error handler via the original reject
+        // selector if it exists on self (CAPPluginCall is Obj-C)
+        let sel = NSSelectorFromString("reject:code:error:data:")
+        if responds(to: sel) {
+            perform(sel, with: message, with: code)
+        }
+    }
+
+    @objc public func resolve() {
+        resolve([:])
+    }
+
+    @objc public func resolve(_ data: PluginCallResultData) {
+        let resultClass: AnyClass? = NSClassFromString("CAPPluginCallResult")
+        if let resultClass = resultClass as? NSObject.Type {
+            let resultObj = resultClass.perform(
+                Selector(("init:")),
+                with: data
+            )?.takeUnretainedValue()
+            if let callResult = resultObj as? CAPPluginCallResult {
+                successHandler?(callResult, self)
+                return
+            }
+        }
+    }
+}
+
+// MARK: - CAPBridgeProtocol shim
+
+extension CAPBridgeProtocol {
+    public var viewController: UIViewController? {
+        return (self as? CAPBridgeViewController) ?? nil
+    }
+
+    public var webView: WKWebView? {
+        return (self as? CAPBridgeViewController)?.webView
+    }
+}
+
+// MARK: - PluginConfig shim
+
+extension PluginConfig {
+    public func getArray(_ configKey: String) -> JSArray? {
+        return getConfigJSON()[configKey] as? JSArray
+    }
+}
+
+// MARK: - JSTypes shim
+
+extension JSTypes {
+    public static func coerceDictionaryToJSObject(_ dictionary: [AnyHashable: Any]?, formattingDatesAsStrings: Bool = false) -> JSObject? {
+        guard let dict = dictionary else { return nil }
+        var result = JSObject()
+        for (key, value) in dict {
+            guard let stringKey = key as? String else { continue }
+            if let boolVal = value as? Bool {
+                result[stringKey] = boolVal
+            } else if let intVal = value as? Int {
+                result[stringKey] = intVal
+            } else if let doubleVal = value as? Double {
+                result[stringKey] = doubleVal
+            } else if let stringVal = value as? String {
+                result[stringKey] = stringVal
+            } else if let dateVal = value as? Date, formattingDatesAsStrings {
+                result[stringKey] = ISO8601DateFormatter().string(from: dateVal)
+            } else if let dictVal = value as? [AnyHashable: Any] {
+                result[stringKey] = coerceDictionaryToJSObject(dictVal, formattingDatesAsStrings: formattingDatesAsStrings) ?? [:]
+            }
+        }
+        return result
+    }
+
+    public static func coerceDictionaryToJSObject(_ dictionary: NSDictionary?, formattingDatesAsStrings: Bool = false) -> JSObject? {
+        guard let dict = dictionary else { return nil }
+        return coerceDictionaryToJSObject(dict as? [AnyHashable: Any], formattingDatesAsStrings: formattingDatesAsStrings)
+    }
+}
